# OKX credentials
OKX_API_KEY=your_api_key_here
OKX_API_SECRET=your_api_secret_here
OKX_API_PASSPHRASE=your_passphrase_here

# Trading configuration
OKX_SYMBOL=BTC/USDT
OKX_TIMEFRAME=1m
FAST_SMA=10
SLOW_SMA=30

# Safety switches
ALLOW_LIVE_TRADING=false
DRY_RUN=true
RISK_FRACTION=0.02
MAX_POSITION_USDT=100
STOP_LOSS_PCT=0.01
TAKE_PROFIT_PCT=0.02
